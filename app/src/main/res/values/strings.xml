    <!-- Troubleshooting -->
    <string name="trouble_title">內置連線異常排除</string>
    <string name="trouble_desc">偵測到通訊受阻，請依照以下步驟重新激活：</string>
    <string name="trouble_step1_t">開啟原廠 App 進行初始化</string>
    <string name="trouble_step1_d">點擊下方按鈕跳轉至原廠控制介面。</string>
    <string name="trouble_step2_t">檢查視覺狀態 (Icon 指引)</string>
    <string name="trouble_step2_d">請確認原廠 App 左下角兩個圖示是否點亮。</string>
    <string name="trouble_status_ok">✅ 正常 (點亮)</string>
    <string name="trouble_status_err">❌ 異常 (灰色)</string>
    <string name="trouble_warn_reboot">⚠️ 若圖示為灰色，請立即「重啟遙控器電源」。</string>
    <string name="trouble_step3_t">滑掉原廠 App 以釋放權限</string>
    <string name="trouble_step3_d">點亮後，請將原廠 App 從「最近工作列表」中滑掉關閉，否則模擬器無法取得串口權限。</string>

