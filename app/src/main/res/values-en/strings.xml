    <string name="tut_welcome_t1">Welcome to Niko Drone Simulator</string>
    <string name="tut_welcome_d1">This is a professional flight training system designed to help you master drone licensing procedures and physics.</string>
    <string name="tut_welcome_t2">Tactical Toolbar</string>
    <string name="tut_welcome_d2">Tap top-right to open toolbar. Includes:\n• Data Toggle: Show/Hide HUD\n• Audio: Mute/Unmute motor/env sounds\n• Virtual Sticks: On-screen touch controls\n• Views: Track/Follow/FPV switch\n• Settings: Mapping &amp; model selection\n• Reset: Instant return to home</string>
    <string name="tut_welcome_t3">Visual Radar HUD</string>
    <string name="tut_welcome_d3">Bottom-left shows position &amp; heading. Red zones are out of bounds; keep flight within limits.</string>
    <string name="tut_welcome_t4">Flight Status Monitoring</string>
    <string name="tut_welcome_d4">Bottom bar shows Alt, Speed, and Distance. Max Alt is 30m; warnings trigger if exceeded.</string>
    <string name="tut_welcome_t5">Arming &amp; Launch</string>
    <string name="tut_welcome_d5">On ground, tap top ARM button or use CSC (Inner-Bottom) on physical sticks to unlock.</string>
    <string name="tut_welcome_t6">Ready to Fly!</string>
